// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Event {
  id         Int      @id @default(autoincrement())
  event_type String   // 'push', 'merge_request', 'issue'
  project_id Int
  project_name String
  payload    String   // JSON string
  status     String   @default("queued") // queued, processing, complete, failed
  error      String?
  created_at DateTime @default(now())
  processed_at DateTime?

  agentRuns AgentRun[]

  @@index([status])
  @@index([created_at])
}

model AgentRun {
  id         Int      @id @default(autoincrement())
  event_id   Int
  agent_name String   // 'onboarding-copilot'
  status     String   // 'success', 'failed'
  input      String   // JSON string
  output     String?  // JSON string
  error      String?
  duration_ms Int      @default(0)
  created_at DateTime @default(now())

  event Event @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@index([agent_name])
  @@index([status])
}

model OnboardingGuide {
  id              String   @id @default(cuid())
  project_id      Int
  project_name    String
  guide_content   String   // Markdown
  starter_issues  String   // JSON string - Array of {title, description, labels}
  gitlab_issue_url String?
  created_at      DateTime @default(now())

  @@index([project_id])
}
