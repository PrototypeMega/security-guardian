// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Event {
  id         Int    @id @default(autoincrement())
  event_type String // 'push'
  project_id Int
  payload    String // JSON string
  status     String @default("queued") // queued, processing, complete, failed
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  agentRuns AgentRun[]
}

model AgentRun {
  id          Int    @id @default(autoincrement())
  event_id    Int
  agent_name  String // 'onboarding-copilot'
  status      String
  output      String? // JSON string
  error_message String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  event Event @relation(fields: [event_id], references: [id], onDelete: Cascade)
}

model OnboardingGuide {
  id                String @id @default(cuid())
  project_id        Int
  guide_content     String // Markdown
  starter_issues    String // JSON string
  gitlab_issue_url  String?
  created_at        DateTime @default(now())
}
